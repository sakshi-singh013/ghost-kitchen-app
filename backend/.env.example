# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ghost_kitchen

# Auth
JWT_SECRET=replace-with-a-long-random-string

# Server
PORT=5000

# Used to build the link inside the "reset your password" email
FRONTEND_URL=http://localhost:5173

# SMTP (used for sending password reset emails)
# If left unset, reset links are printed to the server console instead of
# emailed, so the feature still works while you're developing locally.
# Example values for Gmail: host smtp.gmail.com, port 587, and an
# "app password" (not your normal Gmail password) as SMTP_PASS.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Ghost Kitchen <no-reply@ghostkitchen.app>"
